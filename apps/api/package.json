{
  "name": "api",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "start": "nest start",
    "dev": "nest start --watch",
    "build": "nest build",
    "db:generate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:generate src/database/migrations/placeholder",
    "db:migrate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "db:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seed/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.1005.0",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dataloader": "^2.2.3",
    "graphql": "^16.12.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@apollo/gateway": "^2.13.1",
    "@nestjs/testing": "^11.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/ws": "^8.18.1",
    "supertest": "^7.1.4",
    "ts-morph": "^27.0.2"
  }
}
