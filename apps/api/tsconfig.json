{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": true,
    "removeComments": true,
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
    "incremental": true,
    "strictNullChecks": true
  },
  "include": ["src/**/*"]
}
