{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2023",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    //"declaration": true,
    "removeComments": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "incremental": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*"]
}
