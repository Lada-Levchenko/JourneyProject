{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node16",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "paths": {
      "@types/*": ["./packages/types/src/*"],
      "@ui/*": ["./packages/ui/src/*"],
      "@utils/*": ["./packages/utils/src/*"]
    }
  }
}
